"""Tests for forecast-v2 feature pipeline, model, and writer.

Covers per SOP:
  - Dynamic feature missing handling
  - Time feature boundary cases
  - Score clamp 0-100
  - 12h horizon output
  - Idempotent writer
  - Fixtures: venue without live score, venue with reports, cross-midnight forecast

Run: python -m pytest Data+ML/test/7.6-7.11/test_forecast_v2.py -v
"""

import sys
from datetime import datetime, timedelta, timezone
from pathlib import Path

import pandas as pd

HERE = Path(__file__).resolve().parent
if str(HERE) not in sys.path:
    sys.path.insert(0, str(HERE))

import forecast_v2_feature_pipeline as fp
import forecast_v2_model as fm
import forecast_v2_writer as fw
from conftest import make_venues as _make_venues, make_scores as _make_scores, make_reports as _make_reports


# ═══════════════════════════════════════════════════════════════════════════════
# Feature pipeline tests
# ═══════════════════════════════════════════════════════════════════════════════


class TestDynamicFeatures:
    def test_latest_score_missing_flag_set_when_no_data(self):
        venues = _make_venues(3)
        scores = _make_scores(venues, hours_back=24)
        reports = _make_reports(scores)
        scores_cache = fp._build_lookback_cache(scores)

        feats = fp.compute_dynamic_features(
            "v_1001",  # no scores
            pd.Timestamp(datetime.now(timezone.utc)),
            scores_cache,
            reports,
            venues,
        )
        assert feats["latest_score_missing"] == 1
        assert feats["latest_busyness_score"] == -1.0
        assert feats["latest_busyness_age_minutes"] == 9999.0

    def test_latest_score_present_when_data_exists(self):
        venues = _make_venues(3)
        scores = _make_scores(venues, hours_back=24)
        scores_cache = fp._build_lookback_cache(scores)

        v0_scores = scores[scores["venue_id"] == "v_1000"]
        ref_time = v0_scores["forecast_start_time"].max() + timedelta(hours=1)

        feats = fp.compute_dynamic_features(
            "v_1000",
            pd.Timestamp(ref_time),
            scores_cache,
            pd.DataFrame(),
            venues,
        )
        assert feats["latest_score_missing"] == 0
        assert 0 <= feats["latest_busyness_score"] <= 100

    def test_rolling_features_missing_flag(self):
        venues = _make_venues(3)
        scores = _make_scores(venues, hours_back=24)
        scores_cache = fp._build_lookback_cache(scores)

        v0_scores = scores[scores["venue_id"] == "v_1000"]
        # Use the very first timestamp so lookback is empty
        first_time = v0_scores["forecast_start_time"].min()

        feats = fp.compute_dynamic_features(
            "v_1000",
            pd.Timestamp(first_time),
            scores_cache,
            pd.DataFrame(),
            venues,
        )
        # At the first timestamp, there's no prior data → rolling features should be missing
        assert feats["rolling_mean_1h_missing"] == 1
        assert feats["rolling_mean_1h"] == -1.0

    def test_report_features_for_venue_with_reports(self):
        venues = _make_venues(5)
        scores = _make_scores(venues, hours_back=24)
        reports = _make_reports(scores)
        scores_cache = fp._build_lookback_cache(scores)

        v3_scores = scores[scores["venue_id"] == "v_1003"]
        ref_time = v3_scores["forecast_start_time"].max() + timedelta(hours=1)

        feats = fp.compute_dynamic_features(
            "v_1003",
            pd.Timestamp(ref_time),
            scores_cache,
            reports,
            venues,
        )
        # Should have some reports
        assert feats["recent_report_count_3h"] >= 0
        assert feats["active_report_severity_score_missing"] == 0


class TestTimeFeatures:
    def test_is_weekend(self):
        # Saturday
        saturday = pd.Timestamp("2026-07-04 12:00:00")  # Saturday
        feats = fp.compute_time_features(saturday, offset_hours=0)
        assert feats["is_weekend"] == 1

        # Monday
        monday = pd.Timestamp("2026-07-06 12:00:00")  # Monday
        feats = fp.compute_time_features(monday, offset_hours=0)
        assert feats["is_weekend"] == 0

    def test_business_hours_boundary(self):
        # 7:59 AM
        before = pd.Timestamp("2026-07-06 07:00:00")
        feats = fp.compute_time_features(before, offset_hours=0)
        assert feats["is_business_hours"] == 0

        # 8:00 AM
        at_open = pd.Timestamp("2026-07-06 08:00:00")
        feats = fp.compute_time_features(at_open, offset_hours=0)
        assert feats["is_business_hours"] == 1

        # 6:00 PM
        at_close = pd.Timestamp("2026-07-06 18:00:00")
        feats = fp.compute_time_features(at_close, offset_hours=0)
        assert feats["is_business_hours"] == 1

        # 9:00 PM
        after = pd.Timestamp("2026-07-06 21:00:00")
        feats = fp.compute_time_features(after, offset_hours=0)
        assert feats["is_business_hours"] == 0

    def test_offset_hours_propagates(self):
        ref = pd.Timestamp("2026-07-06 08:00:00")
        feats = fp.compute_time_features(ref, offset_hours=5)
        assert feats["forecast_offset_hours"] == 5
        assert feats["target_hour_of_day"] == 13  # 8+5=13

    def test_cross_midnight_forecast(self):
        """Forecast at 10 PM, offset +3h → 1 AM next day."""
        ref = pd.Timestamp("2026-07-06 22:00:00")
        feats = fp.compute_time_features(ref, offset_hours=3)
        assert feats["target_hour_of_day"] == 1  # 1 AM
        assert feats["hour_of_day"] == 22  # ref hour unchanged
        assert feats["is_business_hours"] == 0  # 1 AM

    def test_is_holiday_stub_is_zero(self):
        ref = pd.Timestamp("2026-07-04 12:00:00")
        feats = fp.compute_time_features(ref)
        assert feats["is_holiday_or_event_stub"] == 0


class TestFeaturePipelineEndToEnd:
    def test_build_synthetic_data_returns_all_frames(self):
        venues, scores, reports = fp.build_synthetic_data(n_venues=10, hours_back=48)
        assert len(venues) == 10
        assert len(scores) > 0
        assert len(reports) > 0

    def test_build_training_samples_has_required_columns(self):
        venues, scores, reports = fp.build_synthetic_data(n_venues=10, hours_back=48)
        training = fp.build_training_samples(scores, venues, reports, max_samples_per_venue=24)
        assert len(training) > 0
        assert "label_score" in training.columns
        assert "label_level" in training.columns
        assert "venue_id" in training.columns
        for feat in fp.DYNAMIC_FEATURES:
            assert feat in training.columns, f"Missing dynamic feature: {feat}"
        for feat in fp.TIME_FEATURES:
            assert feat in training.columns, f"Missing time feature: {feat}"

    def test_build_prediction_samples_has_12h_per_venue(self):
        venues, scores, reports = fp.build_synthetic_data(n_venues=5, hours_back=48)
        pred = fp.build_prediction_samples(venues, scores, reports)
        for vid in venues["venue_id"]:
            v_rows = pred[pred["venue_id"] == vid]
            assert len(v_rows) == 12, f"{vid} has {len(v_rows)} rows, expected 12"


# ═══════════════════════════════════════════════════════════════════════════════
# Model tests
# ═══════════════════════════════════════════════════════════════════════════════


class TestScoreUtilities:
    def test_clamp_score_lower_bound(self):
        assert fm.clamp_score(-5) == 0
        assert fm.clamp_score(-100) == 0

    def test_clamp_score_upper_bound(self):
        assert fm.clamp_score(150) == 100
        assert fm.clamp_score(999) == 100

    def test_clamp_score_within_range(self):
        assert fm.clamp_score(48.4) == 48
        assert fm.clamp_score(48.6) == 49
        assert fm.clamp_score(0) == 0
        assert fm.clamp_score(100) == 100

    def test_score_to_level_boundaries(self):
        assert fm.score_to_level(0) == "quiet"
        assert fm.score_to_level(29.9) == "quiet"
        assert fm.score_to_level(30) == "moderate"
        assert fm.score_to_level(69.9) == "moderate"
        assert fm.score_to_level(70) == "busy"
        assert fm.score_to_level(100) == "busy"


class TestTimeSplit:
    def test_time_split_is_sequential(self):
        df = pd.DataFrame({
            "venue_id": ["v1"] * 100,
            "forecast_for": pd.date_range("2026-07-01", periods=100, freq="h"),
            "label_score": range(100),
        })
        train, val, test = fm.time_split(df)
        assert len(train) + len(val) + len(test) == 100
        # All train times < all val times < all test times
        assert train["forecast_for"].max() <= val["forecast_for"].min()
        assert val["forecast_for"].max() <= test["forecast_for"].min()


class TestModelEndToEnd:
    def test_train_and_evaluate_produces_metrics(self):
        venues, scores, reports = fp.build_synthetic_data(n_venues=10, hours_back=72)
        training = fp.build_training_samples(scores, venues, reports, max_samples_per_venue=48)

        available = [c for c in fm.ALL_FEATURES if c in training.columns]
        metrics, fitted, test_preds = fm.train_and_evaluate(training, available)

        assert len(metrics) > 0
        assert len(fitted) == 3  # Ridge, RF, GBM
        assert len(test_preds) > 0
        for model_name in ["Ridge", "RandomForestRegressor", "GradientBoostingRegressor"]:
            model_metrics = metrics[metrics["model_name"] == model_name]
            assert len(model_metrics) > 0, f"No metrics for {model_name}"

    def test_generate_prediction_curve_has_12h_horizon(self):
        venues, scores, reports = fp.build_synthetic_data(n_venues=5, hours_back=72)
        training = fp.build_training_samples(scores, venues, reports, max_samples_per_venue=48)
        pred_samples = fp.build_prediction_samples(venues, scores, reports)

        available = [c for c in fm.ALL_FEATURES if c in training.columns]
        _, fitted, _ = fm.train_and_evaluate(training, available)

        gbm = fitted["GradientBoostingRegressor"]
        curve = fm.generate_prediction_curves(gbm, pred_samples, available, "GradientBoostingRegressor")

        assert len(curve) > 0
        assert "model_version" in curve.columns
        assert all(curve["model_version"] == "forecast-v2")
        assert all(curve["predicted_score"].between(0, 100))
        for vid in venues["venue_id"]:
            v_curve = curve[curve["venue_id"] == vid]
            assert len(v_curve) == 12, f"{vid}: expected 12 offsets, got {len(v_curve)}"


# ═══════════════════════════════════════════════════════════════════════════════
# Writer tests
# ═══════════════════════════════════════════════════════════════════════════════


class TestWriter:
    def test_clamp_score(self):
        assert fw.clamp_score(150) == 100
        assert fw.clamp_score(-5) == 0

    def test_derive_forecast_for(self):
        base = datetime(2026, 7, 6, 8, 0)
        result = fw.derive_forecast_for(base, 3)
        assert result == datetime(2026, 7, 6, 11, 0)

    def test_cross_midnight_forecast_for(self):
        base = datetime(2026, 7, 6, 22, 0)
        result = fw.derive_forecast_for(base, 3)
        assert result == datetime(2026, 7, 7, 1, 0)

    def test_load_curve_parses_csv(self, tmp_path):
        csv_path = tmp_path / "curve.csv"
        pd.DataFrame([
            {"venue_id": "v_1000", "forecast_for": "2026-07-06 08:00:00",
             "offset_hours": 0, "predicted_score": 48.4, "predicted_level": "moderate",
             "model_version": "forecast-v2", "model_name": "GradientBoostingRegressor",
             "generated_at": "2026-07-06T00:00:00+00:00"},
            {"venue_id": "v_1000", "forecast_for": "2026-07-06 08:00:00",
             "offset_hours": 1, "predicted_score": 52.1, "predicted_level": "moderate",
             "model_version": "forecast-v2", "model_name": "GradientBoostingRegressor",
             "generated_at": "2026-07-06T00:00:00+00:00"},
        ]).to_csv(csv_path, index=False)

        rows = fw.load_curve(csv_path, "forecast-v2")
        assert len(rows) == 2
        assert rows[0]["venue_id"] == "v_1000"
        assert rows[0]["predicted_score"] == 48  # rounded
        assert rows[0]["model_version"] == "forecast-v2"

    def test_load_curve_clamps_scores(self, tmp_path):
        csv_path = tmp_path / "curve.csv"
        pd.DataFrame([
            {"venue_id": "v_1000", "forecast_for": "2026-07-06 08:00:00",
             "offset_hours": 0, "predicted_score": 150.0, "predicted_level": "busy",
             "model_version": "forecast-v2", "model_name": "GradientBoostingRegressor",
             "generated_at": "2026-07-06T00:00:00+00:00"},
        ]).to_csv(csv_path, index=False)

        rows = fw.load_curve(csv_path)
        assert rows[0]["predicted_score"] == 100  # clamped

    def test_dry_run_emits_sql(self, tmp_path, capsys):
        csv_path = tmp_path / "curve.csv"
        pd.DataFrame([
            {"venue_id": "v_1000", "forecast_for": "2026-07-06 08:00:00",
             "offset_hours": 0, "predicted_score": 48.0, "predicted_level": "moderate",
             "model_version": "forecast-v2", "model_name": "GradientBoostingRegressor",
             "generated_at": "2026-07-06T00:00:00+00:00"},
        ]).to_csv(csv_path, index=False)

        rc = fw.main(["--dry-run", "--csv", str(csv_path), "--model-version", "forecast-v2"])
        out = capsys.readouterr().out
        assert rc == 0
        assert "INSERT INTO busyness_forecasts" in out
        assert "ON DUPLICATE KEY UPDATE" in out
        assert "0 written to DB" in out


# ═══════════════════════════════════════════════════════════════════════════════
# SOP fixture tests: edge cases from the SOP spec
# ═══════════════════════════════════════════════════════════════════════════════


class TestSOPEdgeCases:
    """SOP-required fixtures: no live score venue, reports venue, cross-day forecast."""

    def test_venue_without_live_score_still_gets_forecast(self):
        """Venue v_1001 has no busyness_scores → features should have missing flags set."""
        venues = _make_venues(5)
        scores = _make_scores(venues, hours_back=24)  # v_1001 excluded
        reports = _make_reports(scores)

        pred = fp.build_prediction_samples(venues, scores, reports)
        v1001 = pred[pred["venue_id"] == "v_1001"]
        assert len(v1001) == 12  # still gets 12h forecast
        assert all(v1001["latest_score_missing"] == 1)
        assert all(v1001["latest_busyness_score"] == -1.0)

    def test_venue_with_reports_has_severity_score(self):
        """Venue v_1003 has recent reports → severity score should be > 0."""
        venues = _make_venues(5)
        scores = _make_scores(venues, hours_back=24)
        reports = _make_reports(scores)
        scores_cache = fp._build_lookback_cache(scores)

        v3_scores = scores[scores["venue_id"] == "v_1003"]
        ref_time = v3_scores["forecast_start_time"].max() + timedelta(hours=1)

        feats = fp.compute_dynamic_features(
            "v_1003", pd.Timestamp(ref_time), scores_cache, reports, venues,
        )
        # Reports are at the last 5 timestamps, all within 6h of ref_time (+1h offset)
        assert feats["active_report_severity_score"] > 0, \
            f"Expected severity > 0, got {feats['active_report_severity_score']}"

    def test_cross_day_forecast_offset_spans_midnight(self):
        """Forecast starting at 10 PM with 12 offsets should span past midnight."""
        venues = _make_venues(3)
        scores = _make_scores(venues, hours_back=24)
        pred = fp.build_prediction_samples(
            venues, scores, pd.DataFrame(),
            forecast_base_time=datetime(2026, 7, 6, 22, 0, tzinfo=timezone.utc),
        )
        v0 = pred[pred["venue_id"] == "v_1000"]
        target_hours = v0["target_hour_of_day"].tolist()
        # Should see hours wrapping: 22, 23, 0, 1, ...
        assert target_hours[0] == 22
        assert target_hours[1] == 23
        assert target_hours[2] == 0
        assert target_hours[3] == 1

    def test_forecast_score_clamped_in_prediction_curve(self):
        venues, scores, reports = fp.build_synthetic_data(n_venues=3, hours_back=48)
        training = fp.build_training_samples(scores, venues, reports, max_samples_per_venue=24)
        pred_samples = fp.build_prediction_samples(venues, scores, reports)
        available = [c for c in fm.ALL_FEATURES if c in training.columns]
        _, fitted, _ = fm.train_and_evaluate(training, available)

        curve = fm.generate_prediction_curves(
            fitted["GradientBoostingRegressor"], pred_samples, available, "GradientBoostingRegressor",
        )
        assert curve["predicted_score"].between(0, 100).all()
