        {
          "username": "Leena M.",
          "rating": 5,
          "contributor_id": "100329940468160559373",
          "user_review_count": 3,
          "user_photo_count": 0,
          "user_thumbnail": "https://lh3.googleusercontent.com/a/ACg8ocIr1RDqqcnj-1Gq1M6TxYED6YsJ28t3tKB1O4n8Dme4S9J9bw=s120-c-rp-mo-br100",
          "description": "Several hours after waking up feeling my bedroom spinning before even opening my eyes, I headed over to the CityMD on Fulton Street in Manhattan. It was early in the morning, the waiting room was empty, the clerk checked me in and I was seen shortly afterwards. This was certainly better than any Emergency Room experience, although my local one is not too bad. After routine vitals and giving a urine sample, I saw a physician who really listened to my symptoms, asked pertinent questions, and much to my surprise immediately identified the problem and its cause.  Some exercises were recommended and an optional medication was prescribed for the dizziness. Fortunately, within a day the problem resolved.",
          "link": "https://www.google.com/maps/reviews/data=!4m8!14m7!1m6!2m5!1sCi9DQUlRQUNvZENodHljRjlvT21wVFQxZDZPRmhGUzNndFRsaE1NVGxoVkdOT2NFRRAB!2m1!1s0x0:0x94c47e4e7106d651!3m1!1s2@1:CAIQACodChtycF9oOmpTT1d6OFhFS3gtTlhMMTlhVGNOcEE%7C%7C?hl=en",
          "date": "2 months ago",
          "date_iso8601": "2026-04-14T22:53:17+00:00"
        },
        {
