        {
          "username": "Kardashev III",
          "rating": 5,
          "contributor_id": "101887775662332688337",
          "user_review_count": 91,
          "user_photo_count": 15,
          "user_thumbnail": "https://lh3.googleusercontent.com/a/ACg8ocL448k9OhBnDiOzeGsNL2ysPrkv6JGeIMT6y0Wkgo02rT58744=s120-c-rp-mo-ba12-br100",
          "description": "I visited this branch of Duane Reade on Friday 5/12/24 for the first time ever. I went there for my Covid and pneumonia vaccinations. I\u2019m 65 and have visited many pharmacies. By far, the pharmacist on duty that morning was the BEST I have encountered - both in terms of medical knowledge and customer service. I believe her name is Alice (sorry if I am mistaken). She was the only pharmacist on duty on the morning of 5/12/24. She deserves appreciation and commendations from Duane Reade corporate. For additional context, most of my reviews on Google are one star, so five stars mean a lot to me.",
          "link": "https://www.google.com/maps/reviews/data=!4m8!14m7!1m6!2m5!1sChdDSUhNMG9nS0VJQ0FnSUREOTVtcHVRRRAB!2m1!1s0x0:0x31a0fca4a22778d9!3m1!1s2@1:CIHM0ogKEICAgIDD95mpuQE%7C%7C?hl=en",
          "date": "2 years ago",
          "date_iso8601": "2024-04-15T16:30:31+00:00"
        },
