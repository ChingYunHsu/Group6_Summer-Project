        {
          "username": "Brenda Cintron",
          "rating": 1,
          "contributor_id": "109678600483823775650",
          "user_review_count": 6,
          "user_photo_count": 0,
          "user_thumbnail": "https://lh3.googleusercontent.com/a/ACg8ocIXCqPyNviL13kMYa4md9g5cMQTTAvrqPYZ8wFDZNhOVNdPbg=s120-c-rp-mo-br100",
          "description": "If only I could put 0 stars staff is very rude their register machine doesn't work so they only take physical card not TAP this is the third time this has happened to me when I tried paying with TAP and staff was very rude asked me if I was sure I had money in my account and belittle me in front of customers for not having a credit card I hope this place gets shut down soon DO NOT SHOP HERE",
          "link": "https://www.google.com/maps/reviews/data=!4m8!14m7!1m6!2m5!1sCi9DQUlRQUNvZENodHljRjlvT21GRFVFdDFjSFJuVm1KSlJsQktObGhOYjB0V1oyYxAB!2m1!1s0x0:0xf850a415c7c97547!3m1!1s2@1:CAIQACodChtycF9oOmFDUEt1cHRnVmJJRlBKNlhNb0tWZ2c%7C%7C?hl=en",
          "date": "7 months ago",
