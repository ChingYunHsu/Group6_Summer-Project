        {
          "username": "Emma Nelson",
          "rating": 1,
          "contributor_id": "100447323428670489457",
          "user_review_count": 230,
          "user_photo_count": 128,
          "user_thumbnail": "https://lh3.googleusercontent.com/a-/ALV-UjUkYZj7Q4-dXx6wscNyNb13CHupboyLodj4BWScqErKKv5xnRRTfQ=s120-c-rp-mo-ba12-br100",
          "description": "This Duane Reade sucks. Don\u2019t bother shopping here, go to CVS a few blocks away instead. Everything is locked up and the employees don\u2019t care enough to come unlock things for 5-10 minutes after you press the button calling for help. Tried to do a pickup order to avoid waiting 5-10 minutes and found out the workers don\u2019t even get the order until you get to the store, so I had to wait anyway. Spend your money elsewhere!",
          "link": "https://www.google.com/maps/reviews/data=!4m8!14m7!1m6!2m5!1sCi9DQUlRQUNvZENodHljRjlvT21GWFRFOWpkRFJaT1RoSlN6QktVRTAwVTA1TlUxRRAB!2m1!1s0x0:0x7f8fc547df25198b!3m1!1s2@1:CAIQACodChtycF9oOmFXTE9jdDRZOThJSzBKUE00U05NU1E%7C%7C?hl=en",
          "date": "7 months ago",
          "date_iso8601": "2025-11-15T03:40:25+00:00"
        },
        {
          "username": "Halina Pavels",
          "rating": 1,
          "contributor_id": "104882302348872876469",
