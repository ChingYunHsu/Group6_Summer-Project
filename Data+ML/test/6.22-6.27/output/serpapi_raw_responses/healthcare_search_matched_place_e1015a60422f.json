        {
          "username": "Fred Bally",
          "rating": 4,
          "contributor_id": "117043199623411321276",
          "user_review_count": 1,
          "user_photo_count": 0,
          "user_thumbnail": "https://lh3.googleusercontent.com/a/ACg8ocJmsdh2nQVD21SP5wffacnb7i3N_iIY0BdRA9-4S4UXw3Z7=s120-c-rp-mo-br100",
          "description": "When I visit this office, I feel like I'm the only person there. From the time I arrive till I depart, I'm treated with respect, and my needs are top priority. I would have rated 5 stars since there is always room for improvement.",
          "link": "https://www.google.com/maps/reviews/data=!4m8!14m7!1m6!2m5!1sChdDSUhNMG9nS0VJQ0FnTURvaGNPbnhBRRAB!2m1!1s0x0:0x252ee794eae03cc6!3m1!1s2@1:CIHM0ogKEICAgMDohcOnxAE%7C%7C?hl=en",
