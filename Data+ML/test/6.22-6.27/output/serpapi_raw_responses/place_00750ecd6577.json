        {
          "username": "Steven Gianaca",
          "rating": 5,
          "contributor_id": "111282073270970189956",
          "user_review_count": 5,
          "user_photo_count": 0,
          "user_thumbnail": "https://lh3.googleusercontent.com/a-/ALV-UjXPAAPiqeXP1wPFSQTwIaL6PUdx_wcTVIZJBcCWns5r1ho2S8fN=s120-c-rp-mo-br100",
          "description": "I was recommended here by a friend after years of sub-par administrative care at my old GP\u2019s office. From the moment I walked in until the follow up call my experience was stellar. The office was spotless, the staff kind and knowledgeable, and everything oh-so-efficient. I can\u2019t explain how wonderful it was not to have to fill out paper duplicates of forms I\u2019d already provided digitally. Thank you!!",
          "link": "https://www.google.com/maps/reviews/data=!4m8!14m7!1m6!2m5!1sChZDSUhNMG9nS0VJQ0FnTUNRdC15QmNBEAE!2m1!1s0x0:0x23ef228ade84cb30!3m1!1s2@1:CIHM0ogKEICAgMCQt-yBcA%7C%7C?hl=en",
