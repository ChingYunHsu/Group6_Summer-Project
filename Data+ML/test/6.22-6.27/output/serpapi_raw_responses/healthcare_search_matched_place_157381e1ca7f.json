        {
          "username": "Ellen Behar Issersohn",
          "rating": 1,
          "contributor_id": "101865389352858516294",
          "user_review_count": 12,
          "user_photo_count": 0,
          "user_thumbnail": "https://lh3.googleusercontent.com/a/ACg8ocJOwAZ2MFimgTxoWrcyY6zcFzY-4So13sFf_7pR1G5tb270Gg=s120-c-rp-mo-br100",
          "description": "Had surgery in July,2022. Absolutely horrific experiences\nthere as I was physically assaulted 3 times by certain malicious nurses in the 2nd post op. I reported it to my physician and other nursing staff, and hospital complaint department. They told me they were referring my complaints to their legal dept. and told my surgeon not to treat me anymore! Despicable!!!",
          "link": "https://www.google.com/maps/reviews/data=!4m8!14m7!1m6!2m5!1sChZDSUhNMG9nS0VJQ0FnSUNSeVllNk9BEAE!2m1!1s0x0:0x53a08b3e549cc6a0!3m1!1s2@1:CIHM0ogKEICAgICRyYe6OA%7C%7C?hl=en",
          "date": "3 years ago",
          "date_iso8601": "2023-04-05T03:15:46+00:00"
        },
        {
          "username": "Kathy Keller",
          "rating": 5,
          "contributor_id": "103754344910974827502",
          "user_review_count": 58,
          "user_photo_count": 0,
          "user_thumbnail": "https://lh3.googleusercontent.com/a-/ALV-UjWE8WiRxoTM3Q_ULvHupnqL7DYcPFZLornnF0OxkQlHIE984Zh9rQ=s120-c-rp-mo-ba12-br100",
          "description": "This is been my hospital since I moved here 33 years ago. I have Crohn's disease and I have been in every single part of the place I think. Imaging, blood work, inpatient, surgery, surgical procedures, doctor's offices. The dedication and superior treatment I have received is beyond expressing. Sure you meet the odd grouchy or unfriendly medical personnel but considering what they're being asked to do I'm not surprised especially in the age of covid.\n\nI have had my life saved at least three times and my quality of life given back to me. Now that my husband has pancreatic cancer the treatment he is receiving in oncology surgery imaging blood work is beyond belief. We would never go anywhere else.",
          "link": "https://www.google.com/maps/reviews/data=!4m8!14m7!1m6!2m5!1sChdDSUhNMG9nS0VJQ0FnSUQ2N0t5Mzh3RRAB!2m1!1s0x0:0x53a08b3e549cc6a0!3m1!1s2@1:CIHM0ogKEICAgID67Ky38wE%7C%7C?hl=en",
          "date": "4 years ago",
          "date_iso8601": "2021-09-22T22:18:14+00:00"
        },
        {
          "username": "Pasang Lhamo",
