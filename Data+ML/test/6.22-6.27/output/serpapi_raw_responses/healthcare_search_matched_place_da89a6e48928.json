        {
          "username": "Ronald Shuman",
          "rating": 5,
          "contributor_id": "101282221292678689213",
          "user_review_count": 15,
          "user_photo_count": 14,
          "user_thumbnail": "https://lh3.googleusercontent.com/a-/ALV-UjVaTNTobepDgbf_ObEpg_8ussS8Qn0rlSeKTeIC4XYbJ7ifDN6R=s120-c-rp-mo-ba12-br100",
          "description": "I can\u2019t recommend Dr. Jehan Nadeem at One Medical (Chelsea) highly enough.\n\nHe is exactly what a primary care physician should be. Dr. Nadeem takes his time, listens carefully, and approaches care with real intellectual curiosity. He asks thoughtful questions, looks at the full picture, and never rushes the conversation.\n\nWhat I appreciate most is that he listens without judgment and makes you feel genuinely heard. Appointments feel collaborative, thorough, and grounded in trust \u2014 not transactional.\n\nIf you\u2019re looking for a PCP who is smart, attentive, and truly invested in understanding you as a person, Dr. Nadeem is exceptional.",
          "link": "https://www.google.com/maps/reviews/data=!4m8!14m7!1m6!2m5!1sCi9DQUlRQUNvZENodHljRjlvT25aNFMyZFllV3BuV1dvM01FcFdhR0kxZWsxQmJWRRAB!2m1!1s0x0:0x3050bf161bd382cb!3m1!1s2@1:CAIQACodChtycF9oOnZ4S2dYeWpnWWo3MEpWaGI1ek1BbVE%7C%7C?hl=en",
          "date": "4 months ago",
