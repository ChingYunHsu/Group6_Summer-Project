        {
          "username": "Mohamed Sammy Hussien",
          "rating": 1,
          "contributor_id": "103741215989290151417",
          "user_review_count": 33,
          "user_photo_count": 4,
          "user_thumbnail": "https://lh3.googleusercontent.com/a-/ALV-UjWcw_ISjwgccWJlaMVyVzWHA3RxYZgQjFcs2-u49pDlMuvtqbrt=s120-c-rp-mo-ba12-br100",
          "description": "I\u2019ve always had positive experiences at this office, especially with Dr. Caroline Coicou \u2014 she\u2019s truly exceptional, compassionate, and always takes the time to care for her patients. Unfortunately, our most recent visit was disappointing. Since Dr. Coicou was fully booked, we were scheduled with Dr. Terry Seetoe. Due to heavy traffic and an accident near the Queens Midtown Tunnel, we arrived late \u2014 but the office was empty when we got there. The front desk staff, who were kind as always, informed us that the doctor would not see us. We explained that we had driven 1.5 hours and that my elderly father had taken a fall the day before and needed medical attention. Despite this, Dr. Seetoe declined to see him. It was disheartening to feel that compassion and flexibility were missing in a situation involving an elderly patient in need. While the staff is generally wonderful, this particular with this specific doctor experience left us disappointed.",
          "link": "https://www.google.com/maps/reviews/data=!4m8!14m7!1m6!2m5!1sChZDSUhNMG9nS0VKR0F6SVQtd2Zya0JnEAE!2m1!1s0x0:0x2b7a4533c78299b1!3m1!1s2@1:CIHM0ogKEJGAzIT-wfrkBg%7C%7C?hl=en",
          "date": "a year ago",
          "date_iso8601": "2025-05-09T10:59:07+00:00"
        },
