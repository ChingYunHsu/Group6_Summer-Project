        {
          "username": "Marilyn H.",
          "rating": 1,
          "contributor_id": "107185741121933152395",
          "user_review_count": 3,
          "user_photo_count": 0,
          "user_thumbnail": "https://lh3.googleusercontent.com/a-/ALV-UjW15WS1QFFk8G5Smmrh0t5L4x5SY6tYIGX9NQKYVmtaaSpBcjZZ=s120-c-rp-mo-br100",
          "description": "I have been a patient at Family Health Center of Harlem for over a year, and my experience has been extremely frustrating. Today I was told I needed to be seen every three months to get my prescription refilled, but this was never clearly explained to me. Instead, I have had to call every month just to try to get my medication.\n\nNow I am without my medication, which is unsafe and unacceptable. I also feel Medicaid patients are not given the proper information or support. I am now urgently looking for a new doctor.",
          "link": "https://www.google.com/maps/reviews/data=!4m8!14m7!1m6!2m5!1sCi9DQUlRQUNvZENodHljRjlvT20xWGVHSk1kbVJNTjFWaVdtbEVRbU5ZZVhOUFUyYxAB!2m1!1s0x0:0xed6584ad8e56a218!3m1!1s2@1:CAIQACodChtycF9oOm1XeGJMdmRMN1ViWmlEQmNYeXNPU2c%7C%7C?hl=en",
