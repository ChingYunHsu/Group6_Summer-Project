        {
          "username": "Franchesca Duran",
          "rating": 5,
          "contributor_id": "110100215032180288543",
          "user_review_count": 7,
          "user_photo_count": 2,
          "user_thumbnail": "https://lh3.googleusercontent.com/a-/ALV-UjUQBKZtq3apS6SOCmFlculqkXSTG2euJpDZ3sFuzpw3QXC56yNN=s120-c-rp-mo-br100",
          "description": "I\u2019m in town visiting family and won\u2019t be leaving till after the new year and I came in not feeling well. From the moment I was checked in, brought to the back has been nothing but a great experience for me. The staff, nurses and doctor were all really great and helpful and I felt supported and cared for start to finish. Wait time was not long at all just average like I expected. Anytime I\u2019m in New York and I need medical care I will choose to come back here. I have no complaints. Great hospitality, great emergency care. They even gave me food which include a sandwich, cookies and a drink so I could take my medicine with food on my stomach. They were great.",
          "link": "https://www.google.com/maps/reviews/data=!4m8!14m7!1m6!2m5!1sCi9DQUlRQUNvZENodHljRjlvT21sdU9HcDFVMU4yY0hWblZWZEZjRFZ4WWt4cWQyYxAB!2m1!1s0x0:0x5efa7abe8c75519e!3m1!1s2@1:CAIQACodChtycF9oOmluOGp1U1N2cHVnVVdFcDVxYkxqd2c%7C%7C?hl=en",
