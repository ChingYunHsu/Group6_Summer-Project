# Copy this file to .env and replace placeholder values.
API_KEY=replace-with-api-key
BESTTIME_API_KEY=replace-with-besttime-key
GOOGLE_MAPS_API_KEY=replace-with-google-maps-key
GEMINI_API_KEY=replace-with-gemini-key

# MySQL connection (matches docker-compose.yml defaults)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=clearpath_app
DB_PASSWORD=clearpath_app
DB_NAME=clearpath

# pymysql connection pool tuning (src/db.py)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Set to true only against a real MySQL instance with tablespace encryption
# enabled. The app hard-fails on startup if the check doesn't pass. Leave
# false for local dev / CI / anywhere without a live encrypted MySQL.
DB_ENCRYPTION_CHECK=false

JWT_SECRET=replace-with-a-real-32-byte-secret

# Redis logout/revocation blacklist (src/token_blacklist.py)
REDIS_URL=redis://127.0.0.1:6379/0
